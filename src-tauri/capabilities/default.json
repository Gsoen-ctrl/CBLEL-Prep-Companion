{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://github.com/*" }, { "url": "https://objects.githubusercontent.com/*" }, { "url": "https://api.github.com/*" }]
    },
    "fs:default",
    "shell:default",
    "os:default",
    "opener:default",
    "opener:allow-open-url"
  ]
}
